# ════════════════════════════════════════════════════════════════════
#   Variables de entorno necesarias para correr la app.
#
#   Cómo usar este archivo:
#     1. Copia este archivo y renómbralo a ".env"  (sin el .example)
#     2. Rellena cada valor siguiendo las instrucciones de abajo
#     3. El archivo .env está en .gitignore y NUNCA se sube a GitHub
# ════════════════════════════════════════════════════════════════════


# ─── 1. Conexión a la base de datos (Supabase Postgres) ─────────────
#
# Dónde sacarlo:
#   1. Entra a tu proyecto en https://supabase.com/dashboard
#   2. Arriba a la derecha, clic en el botón "Connect"
#   3. Selecciona la pestaña "Transaction pooler" (puerto 6543)
#   4. Copia el "Connection string" completo
#   5. Reemplaza [YOUR-PASSWORD] por la contraseña que pusiste cuando
#      creaste el proyecto (o resetéala en Settings → Database)
#
DATABASE_URL="postgresql://postgres.TU-REFERENCIA:TU-PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres"


# ─── 2. URL pública de tu proyecto Supabase ─────────────────────────
#
# Dónde sacarlo:
#   Dashboard de Supabase → Project Settings (engranaje) → API → Project URL
#
NEXT_PUBLIC_SUPABASE_URL="https://TU-REFERENCIA.supabase.co"


# ─── 3. Anon key (clave pública del frontend) ───────────────────────
#
# Dónde sacarlo:
#   Dashboard de Supabase → Project Settings → API → Project API keys → anon (public)
#
# Es seguro exponer esta clave en el navegador — Supabase la diseñó para
# eso. La seguridad real la dan las políticas RLS de tu base de datos.
#
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ......TU-ANON-KEY......"
